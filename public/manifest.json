{
  "manifest_version": 3,
  "name": "CF Enhancer",
  "version": "1.0.0",
  "description": "A better Codeforces experience",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://codeforces.com/*",
    "https://codeforces.com/api/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://codeforces.com/*"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "CF Enhancer",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}